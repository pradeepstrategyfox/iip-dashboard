{
  "version": 2,
  "builds": [
    { "src": "api/data.js", "use": "@vercel/node" },
    { "src": "api/leads.js", "use": "@vercel/node" },
    { "src": "api/update.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/data", "dest": "/api/data.js" },
    { "src": "/api/refresh", "dest": "/api/data.js?refresh=true" },
    { "src": "/api/leads", "dest": "/api/leads.js" },
    { "src": "/api/leads/refresh", "dest": "/api/leads.js?refresh=true" },
    { "src": "/api/update", "dest": "/api/update.js" },
    { "src": "/leads/?", "dest": "/public/leads/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
